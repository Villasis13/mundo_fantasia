APP_NAME="ASSU VENTAS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://emy_pet.test/

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=emy_pet
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.tuservidor.com
MAIL_PORT=465
MAIL_USERNAME=tu@correo.com
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS="tu@correo.com"
MAIL_FROM_NAME="${APP_NAME}"
# Correo de respaldo para notificaciones internas
MAIL_BACKUP=backup@correo.com

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Token del servicio externo Migo (notificaciones/SMS)
MIGO_TOKEN=

# ─── Facturación electrónica SUNAT ────────────────────────────────────────────
# Endpoint de envío de comprobantes:
#   Producción: https://e-factura.sunat.gob.pe/ol-ti-itcpfegem/billService
#   Pruebas:    https://e-beta.sunat.gob.pe/ol-ti-itcpfegem-beta/billService
APP_FACT=https://e-beta.sunat.gob.pe/ol-ti-itcpfegem-beta/billService

# Usar certificado cacert local para cURL (1 = Sí, 2 = No)
APP_CACERT_FACT=1

# Indicar si el sistema corre en entorno local (1 = Sí, 2 = No)
# Afecta la resolución de rutas de archivos temporales de facturación
APP_FACT_LOCAL=1

# ─── Dimensiones de logo en PDFs ──────────────────────────────────────────────
ANCHO_LOGO_PDF=50
ALTO_LOGO_PDF=20
IZQU_LOGO_PDF_A4=36
IZQU_LOGO_PDF_TICKET=13
